<Window x:Class="PRK2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Інтерактивна карта знань"
        Width="900" Height="600"
        MinWidth="700" MinHeight="450">

    <DockPanel LastChildFill="True">

        <!-- 🔹 Верхня панель -->
        <Grid DockPanel.Dock="Top" Background="#2C3E50" Height="60">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Заголовок -->
            <TextBlock Text="Інтерактивна карта знань"
                       Foreground="White"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Margin="15,0"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="10">

                <Button Content="Головна" Width="90" Margin="5" Click="Home_Click"/>
                <Button Content="Список" Width="90" Margin="5" Click="List_Click"/>
                <Button Content="Налаштування" Width="120" Margin="5" Click="Settings_Click"/>
                <Button Content="Назад" Width="80" Margin="5" Click="Back_Click"/>
                <Button Content="Вихід" Width="80" Margin="5" Click="Exit_Click"/>

            </StackPanel>
        </Grid>

        <!-- 🔹 Основна область -->
        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Контент -->
            <Border Grid.Row="0"
                    Background="#ECF0F1"
                    CornerRadius="10"
                    Padding="10">

                <Frame x:Name="MainFrame"/>
            </Border>

            <!-- Статус -->
            <StatusBar Grid.Row="1">
                <TextBlock x:Name="StatusText" Text="Готово"/>
            </StatusBar>

        </Grid>

    </DockPanel>
</Window>
