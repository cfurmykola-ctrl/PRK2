<Window x:Class="KnowledgeMap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Інтерактивна карта знань"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400">

    <DockPanel>

        <!-- Верхнє меню -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Background="LightGray">
            <Button Content="Головна" Width="100" Margin="5" Click="Home_Click"/>
            <Button Content="Список" Width="100" Margin="5" Click="List_Click"/>
            <Button Content="Налаштування" Width="120" Margin="5" Click="Settings_Click"/>
        </StackPanel>

        <!-- Нижня панель -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="StatusText" Text="Готово"/>
        </StatusBar>

        <!-- Основна область -->
        <Frame x:Name="MainFrame"/>

    </DockPanel>
</Window>