<Page x:Class="PRK2.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MainPage"
      Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">

        <Border Background="{DynamicResource PanelBrush}"
                CornerRadius="10"
                Padding="20">

            <StackPanel>

                <TextBlock Text="{DynamicResource AppTitle}"
                           FontSize="22"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{DynamicResource WelcomeText}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <TextBlock Text="{DynamicResource LoginLabel}"
           Margin="0,0,0,5"/>

                <TextBox x:Name="LoginBox"
                         Width="250"
                         Margin="0,0,0,10"/>

                <TextBlock Text="{DynamicResource PasswordLabel}"
           Margin="0,0,0,5"/>

                <PasswordBox x:Name="PasswordBox"
                             Width="250"
                             Margin="0,0,0,15"/>

                <Button Content="{DynamicResource LoginButton}"
        Width="150"
        Click="Login_Click"/>

                <TextBlock x:Name="ErrorText"
                           Foreground="Red"
                           Margin="0,10,0,0"/>

            </StackPanel>

        </Border>

    </Grid>
</Page>