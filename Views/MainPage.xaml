<Page x:Class="PRK2.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Інтерактивна карта знань"
                       FontSize="22"
                       Margin="0,0,0,15"/>

            <TextBlock TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       Text="Якщо ви студент — перейдіть на сторінку 'Список' для перегляду та пошуку тем. Якщо ви викладач — увійдіть у систему, щоб отримати доступ до редагування та додавання тем."/>

            <TextBlock Text="Логін"/>
            <TextBox x:Name="LoginBox" Width="200"/>

            <TextBlock Text="Пароль" Margin="0,10,0,0"/>
            <PasswordBox x:Name="PasswordBox" Width="200"/>

            <Button Content="Увійти"
                    Width="150"
                    Margin="0,10,0,0"
                    Click="Login_Click"/>
            

        </StackPanel>

    </Grid>

</Page>
