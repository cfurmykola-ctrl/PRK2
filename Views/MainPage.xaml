<Page x:Class="PRK2.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Border Background="#ECF0F1"
                CornerRadius="10"
                Padding="20"
                Margin="20">

            <StackPanel>

                <TextBlock Text="Головна сторінка"
                           FontSize="22"
                           Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Введіть текст:"
                               VerticalAlignment="Center"
                               Width="130"/>

                    <TextBox x:Name="InputBox" Width="200"/>
                </StackPanel>

                <Button Content="Пошук"
                        Width="150"
                        HorizontalAlignment="Center"
                        Click="Button_Click"/>

                <TextBlock x:Name="ResultText"
                           Margin="0,15,0,0"
                           FontSize="16"/>

            </StackPanel>

        </Border>

    </Grid>

</Page>
