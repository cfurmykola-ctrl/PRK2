<Page x:Class="KnowledgeMap.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">

        <StackPanel>

            <TextBlock Text="Головна сторінка"
                       FontSize="20"
                       Margin="0,0,0,10"/>

            <Label Content="Введіть текст:"/>

            <TextBox x:Name="InputBox" Width="200" Margin="0,0,0,10"/>

            <Button Content="Натисни мене"
                    Width="150"
                    Click="Button_Click"/>

            <TextBlock x:Name="ResultText"
                       Margin="0,10,0,0"/>

        </StackPanel>

    </Grid>
</Page>