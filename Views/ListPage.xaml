<Page x:Class="PRK2.Views.ListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Пошук тем"/>
            <TextBox Width="200" Margin="0,5,0,10"/>

            <ListBox Height="150"/>

            <StackPanel Margin="0,20,0,0">

                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="Редагування тем" FontSize="16"/>

                <Button Content="Додати тему" Width="150" Margin="5"/>
                <Button Content="Редагувати тему" Width="150" Margin="5"/>
                <Button Content="Видалити тему" Width="150" Margin="5"/>

            </StackPanel>

        </StackPanel>

    </Grid>

</Page>
