<Page x:Class="PRK2.Views.ListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:PRK2"
      Title="ListPage"
      Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- Ліва частина -->
        <Border Grid.Column="0"
                Background="{DynamicResource PanelBrush}"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,10,0">

            <StackPanel>
                <TextBlock Text="{DynamicResource Search}"
                           FontSize="16"
                           Margin="0,0,0,5"/>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <TreeView x:Name="TopicsTree"
                          ItemsSource="{Binding FilteredTopics}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          Height="500">

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Subtopics}">
                            <TextBlock Text="{Binding Title}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </StackPanel>
        </Border>

        <!-- Права частина -->
        <Border Grid.Column="1"
                Background="{DynamicResource PanelBrush}"
                CornerRadius="10"
                Padding="15">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Режим студента: доступний тільки перегляд і пошук."
                               Margin="0,0,0,15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static local:App.CurrentUser}, Path=IsAdmin}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Блок для викладача -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static local:App.CurrentUser}, Path=IsAdmin}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="{DynamicResource Add}"
                                   FontSize="18"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Нова тема (UA)" Margin="0,0,0,5"/>
                        <TextBox x:Name="NewTopicUkBox"
                                 Width="250"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="New topic (EN)" Margin="0,0,0,5"/>
                        <TextBox x:Name="NewTopicEnBox"
                                 Width="250"
                                 Margin="0,0,0,10"/>

                        <Button Content="{DynamicResource Add}"
                                Width="140"
                                Margin="0,0,0,20"
                                Click="Add_Click"/>

                        <TextBlock Text="Нова підтема (UA)" Margin="0,0,0,5"/>
                        <TextBox x:Name="NewSubtopicUkBox"
                                 Width="250"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="New subtopic (EN)" Margin="0,0,0,5"/>
                        <TextBox x:Name="NewSubtopicEnBox"
                                 Width="250"
                                 Margin="0,0,0,10"/>

                        <Button Content="{DynamicResource AddSubtopic}"
                                Width="160"
                                Margin="0,0,0,20"
                                Click="AddSubtopic_Click"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource EditTitle}"
                               FontSize="18"
                               Margin="0,10,0,15"/>

                    <TextBlock Text="Назва (UA)" Margin="0,0,0,5"/>
                    <TextBox x:Name="EditTitleUkBox"
                             Text="{Binding EditTitleUk, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Title (EN)" Margin="0,0,0,5"/>
                    <TextBox x:Name="EditTitleEnBox"
                             Text="{Binding EditTitleEn, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Опис (UA)" Margin="0,0,0,5"/>
                    <TextBox x:Name="EditDescriptionUkBox"
                             Text="{Binding EditDescriptionUk, UpdateSourceTrigger=PropertyChanged}"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Description (EN)" Margin="0,0,0,5"/>
                    <TextBox x:Name="EditDescriptionEnBox"
                             Text="{Binding EditDescriptionEn, UpdateSourceTrigger=PropertyChanged}"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,15"/>

                    <WrapPanel>
                        <Button Content="{DynamicResource Save}"
                                Width="120"
                                Margin="0,0,10,0"
                                Click="SaveEdit_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static local:App.CurrentUser}, Path=IsAdmin}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="{DynamicResource Delete}"
                                Width="120"
                                Click="Delete_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static local:App.CurrentUser}, Path=IsAdmin}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>